# ──────────────────────────────────────────────────────────────────────────────
# Переменные окружения Docker-стека (НЕ путать с backend/.env приложения Laravel).
# `make init` создаёт .env автоматически и подставляет имя проекта и UID/GID хоста.
# ──────────────────────────────────────────────────────────────────────────────

# Имя compose-проекта (префикс контейнеров/сети/томов). Должно быть уникальным
# на машине. make init подставит имя каталога проекта.
COMPOSE_PROJECT_NAME=app

# Домен проекта для локальной маршрутизации через Traefik:
#   http://<PROJECT_DOMAIN>.localhost       — сайт (Next.js)
#   http://api.<PROJECT_DOMAIN>.localhost   — API + Filament admin
# make init подставит имя каталога проекта.
PROJECT_DOMAIN=app

# Маппинг пользователя контейнеров под хостовые UID/GID (чтобы файлы в bind-mount
# не были root). make init подставит реальные id хоста.
# macOS: обычно 501/20. Linux: как правило 1000/1000.
UID=501
GID=20

# ── База данных (используется и контейнером postgres, и приложением Laravel) ──
# Внутри сети Docker хост БД = "postgres", хост Redis = "redis".
# Порты на хост публикуются эфемерно (см. make ports) — конфликтов между проектами нет.
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret
