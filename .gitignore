# ── Окружение ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.prod.example

# Локальный Docker-override (проектный, по конвенции не коммитится; см. *.example).
/compose.override.yaml

# ── Backend (Laravel) ─────────────────────────────────────────────────────────
/backend/vendor/
/backend/node_modules/
/backend/.env
/backend/.env.*
!/backend/.env.example
/backend/storage/*.key
/backend/storage/app/public/*
/backend/storage/framework/cache/data/*
/backend/storage/framework/sessions/*
/backend/storage/framework/views/*
/backend/storage/logs/*
/backend/public/storage
/backend/public/build
/backend/.phpunit.result.cache

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.env*.local
/frontend/next-env.d.ts

# ── ОС / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
