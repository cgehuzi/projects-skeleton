# Боевое окружение. Скопируйте в .env.prod и заполните секреты (в .gitignore).
# Использование: docker compose -f compose.prod.yaml --env-file .env.prod ...

COMPOSE_PROJECT_NAME=app

# Реестр и тег публикуемых образов (CI). Локально можно оставить дефолты.
REGISTRY=ghcr.io/cgehuzi/projects-skeleton
TAG=latest

# Публичный адрес и порт edge (TLS обычно терминирует внешний LB/прокси).
APP_URL=https://example.com
HTTP_PORT=80

# Ключ приложения Laravel (обязателен!). Сгенерировать:
#   docker compose -f compose.prod.yaml run --rm php php artisan key:generate --show
APP_KEY=
APP_LOCALE=ru

# База данных. В реальном проде — managed-сервис: задать внешний DB_HOST и убрать
# сервис postgres из compose.prod.yaml.
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=

# Redis (или внешний managed).
REDIS_HOST=redis
REDIS_PORT=6379
